   "source": [
    "#Udało mi się pobrać plik, ale nie udało się go zapisać na środowisku. Mam bląd "File Save Error for PD_Lab2_yn115092.ipynb".\n",
    "#Z tego powodu, commit "Lab2 Urochomienie kodu" tylko zrobił dodatkowy folder z kodem bez zmian.\n",
    "#Mam zapisane zdjęcia urochomianego kodu, jeśli będzie potrzebny pokażę Panu."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "953bee31-d8bf-4a51-b1e3-20feff3884b4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Spark 4.0.0-preview2 — gotowy\n"
     ]
    }
   ],
   "source": [
    "from pyspark.sql import SparkSession\n",
    "\n",
    "spark = (\n",
    "    SparkSession.builder\n",
    "    .appName(\"Lab2-Transactions\")\n",
    "    .getOrCreate()\n",
    ")\n",
    "spark.sparkContext.setLogLevel(\"WARN\")\n",
    "print(f\"Spark {spark.version} — gotowy\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f71e1bb9-d8f7-4806-8060-7083858cb463",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = spark.read.json(\"data/transactions_10k.jsonl\")\n",
    "\n",
    "print(f\"Liczba rekordów: {df.count()}\")\n",
    "df.printSchema()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "39dde09d-f344-4ecc-8078-74ced0e0159a",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyspark.sql.functions import to_timestamp, col\n",
    "\n",
    "df = df.withColumn(\"timestamp\", to_timestamp(col(\"timestamp\"), \"yyyy-MM-dd HH:mm:ss\"))\n",
    "\n",
    "df.printSchema() "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8a9d1815-5090-4bac-aa8f-2db1da975e42",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyspark.sql.functions import avg, window, col, asc\n",
    "\n",
    "gdn_hourly_avg = (\n",
    "    df.filter(col(\"store\") == \"Gdańsk\")\n",
    "    .groupBy(window(\"timestamp\", \"1 hour\"))\n",
    "    .agg(avg(\"amount\").alias(\"srednia_PLN\"))\n",
    "    .orderBy(asc(\"srednia_PLN\"))\n",
    ")\n",
    "\n",
    "(\n",
    "    gdn_hourly_avg\n",
    "    .select(\n",
    "        col(\"window.start\").alias(\"od\"),\n",
    "        col(\"window.end\").alias(\"do\"),\n",
    "        \"srednia_PLN\"\n",
    "    )\n",
    "    .show(truncate=False)\n",
    ") #Godzina z najniższą średnią to pierwszy wiersz"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "40e8535b-1556-42f1-9288-82764e040749",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyspark.sql.functions import count\n",
    "\n",
    "filtered = df.filter(\n",
    "    (col(\"timestamp\") >= \"2026-04-12 09:00:00\") &\n",
    "    (col(\"timestamp\") <  \"2026-04-12 09:30:00\")\n",
    ")\n",
    "\n",
    "category_counts = (\n",
    "    filtered\n",
    "    .groupBy(\"category\")\n",
    "    .agg(count(\"tx_id\").alias(\"liczba_tx\"))\n",
    "    .orderBy(\"category\")\n",
    ")\n",
    "\n",
    "category_counts.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d51675b7-7b87-4885-b458-17811e2b323c",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyspark.sql.functions import desc\n",
    "\n",
    "quarter = (\n",
    "    df.groupBy(window(\"timestamp\", \"15 minutes\"))\n",
    "    .agg(count(\"tx_id\").alias(\"liczba_tx\"))\n",
    "    .orderBy(desc(\"liczba_tx\"))\n",
    ")\n",
    "\n",
    "(\n",
    "    quarter\n",
    "    .select(\n",
    "        col(\"window.start\").alias(\"od\"),\n",
    "        col(\"window.end\").alias(\"do\"),\n",
    "        \"liczba_tx\"\n",
    "    )\n",
    "    .show(truncate=False)\n",
    ") #Szczyt transakcji to pierwszy wiersz"
   ]
  }
 ],
